<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Prefer the air-gap local feed when it contains the exact requested package. -->
    <add key="LocalPackages" value="./vendor/LocalPackages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
