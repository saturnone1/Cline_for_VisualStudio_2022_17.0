          <ButtonText>LIG VS</ButtonText>
          <CommandName>View.LIGVS</CommandName>
          <ToolTipText>Open LIG VS chat window</ToolTipText>
        </Strings>
      </Button>
    </Buttons>
  </Commands>

  <Symbols>
    <GuidSymbol name="guidVsClineAgentPackage" value="{ADCC53D2-7B09-4F8D-8534-1FF693AED219}" />

    <GuidSymbol name="guidVsClineAgentCmdSet" value="{AB1DE66B-E5D1-45D4-839F-ABCE67585458}">
      <IDSymbol name="grpAIAgentMenu" value="0x1020" />
      <IDSymbol name="cmdOpenChatWindow" value="0x0100" />
