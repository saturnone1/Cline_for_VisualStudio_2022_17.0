  <Extern href="stdidcmd.h" />
  <Extern href="vsshlids.h" />

  <Commands package="guidVsClineAgentPackage">
    <Groups>
      <Group guid="guidVsClineAgentCmdSet" id="grpAIAgentMenu" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_VIEW" />
      </Group>
    </Groups>

    <Buttons>
      <Button guid="guidVsClineAgentCmdSet" id="cmdOpenChatWindow" priority="0x0100" type="Button">
        <Parent guid="guidVsClineAgentCmdSet" id="grpAIAgentMenu" />
