<UserControl x:Class="VsClineAgent.ToolWindows.ChatToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
            Background="#1E1E1E">
    <Grid>
        <wv2:WebView2 x:Name="webView" Visibility="Collapsed" />

        <StackPanel x:Name="loadingPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <Grid Width="132"
                  Height="132"
                  Margin="0,0,0,16">
                <Border Width="124"
                        Height="124"
                        Background="Transparent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000"
                                          BlurRadius="28"
                                          ShadowDepth="8"
                                          Opacity="0.32" />
                    </Border.Effect>
                    <Image x:Name="loadingLogoImage"
                           Width="124"
                           Height="124"
                           Stretch="Uniform" />
                </Border>
            </Grid>
            <TextBlock x:Name="loadingTitleText"
                       Text="LIG VS"
                       Foreground="#CCCCCC"
                       FontSize="32"
                       FontWeight="Black"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
            <TextBlock x:Name="loadingBrandText"
                       Text="by M&amp;S.Team3"
                       Foreground="#888888"
                       FontSize="12"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,14" />
            <TextBlock x:Name="statusText"
                       Text="LIG VS를 준비하는 중입니다..."
                       Foreground="#888888"
                       FontSize="12"
                       HorizontalAlignment="Center" />
            <ProgressBar x:Name="loadingProgress"
                         IsIndeterminate="True"
                         Width="220"
                         Height="4"
                         Margin="0,12,0,0"
                         Foreground="#0E70C0"
                         Background="#333333"
                         BorderThickness="0" />
        </StackPanel>

        <TextBox x:Name="errorText"
                 Visibility="Collapsed"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 Foreground="#F44747"
                 Background="#1E1E1E"
                 BorderBrush="#3C3C3C"
                 FontFamily="Consolas"
                 FontSize="12"
                 Margin="16"
                 Padding="12"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 Text="" />
    </Grid>
</UserControl>
